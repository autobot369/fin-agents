# ══════════════════════════════════════════════════════════════════
#  fin-agents — Environment Variable Template
#  Copy to .env and fill in your values:  cp .env.example .env
# ══════════════════════════════════════════════════════════════════


# ── Gemini (sip_execution_mas — Nodes 2, 3, 4) ───────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here


# ── Alpaca (Node 5 — US ETF execution) ───────────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_PAPER=true


# ── Dhan (Node 5 — Indian ETF execution, BSE/NSE) ────────────────────────────
DHAN_CLIENT_ID=your_dhan_client_id_here
DHAN_ACCESS_TOKEN=your_dhan_access_token_here


# ── etf-selection-mas (original Claude-based MAS) ────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# ── Optional news APIs (upgrades over DuckDuckGo) ────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here
NEWS_API_KEY=your_newsapi_key_here


# ── Behaviour flags ───────────────────────────────────────────────────────────
DRY_RUN=true
